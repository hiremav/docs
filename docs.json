{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Mav",
  "description": "Mav is an AI-powered lead engagement platform that qualifies insurance leads via SMS and connects them to agents through live call transfers.",
  "colors": {
    "primary": "#3082FF",
    "light": "#EFF6FF",
    "dark": "#170834"
  },
  "favicon": {
    "light": "/images/Mav-logo-collapsed.png",
    "dark": "/images/Mav-logo-collapsed.png"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Support",
          "icon": "life-buoy",
          "href": "mailto:support@hiremav.com"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": [
              "mav-next/introduction",
              "mav-next/how-mav-works",
              "mav-next/quickstart"
            ]
          },
          {
            "group": "Agents",
            "icon": "robot",
            "pages": [
              "mav-next/agents-overview",
              "mav-next/configuring-an-agent",
              "mav-next/re-engagement",
              "mav-next/testing-an-agent",
              "mav-next/agent-metrics"
            ]
          },
          {
            "group": "Contacts",
            "icon": "address-book",
            "pages": [
              "mav-next/contacts-overview",
              "mav-next/filtering-contacts",
              "mav-next/call-recordings",
              "mav-next/converting-a-contact"
            ]
          },
          {
            "group": "Conversations & Channels",
            "icon": "comments",
            "pages": [
              "mav-next/sms",
              "mav-next/voice",
              "mav-next/rep-transfers"
            ]
          },
          {
            "group": "Compliance",
            "icon": "shield-check",
            "pages": [
              "mav-next/tcpa-and-consent",
              "mav-next/opt-out-and-help",
              "mav-next/scrubs-dnc-blocked-numbers",
              "mav-next/state-rules"
            ]
          },
          {
            "group": "Lead Sources & Routing",
            "icon": "share-nodes",
            "pages": [
              "mav-next/marketing-sources",
              "mav-next/lead-boxes"
            ]
          },
          {
            "group": "Importing & Exporting",
            "icon": "file-import",
            "pages": [
              "mav-next/importing-contacts",
              "mav-next/exporting-contacts"
            ]
          },
          {
            "group": "Settings",
            "icon": "gear",
            "pages": [
              "mav-next/account-and-transfer-hours",
              "mav-next/users-and-roles"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Changelog",
            "icon": "sparkles",
            "pages": [
              "changelog/overview"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Log in to Mav",
      "href": "https://app.hiremav.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/hiremav",
      "linkedin": "https://linkedin.com/company/hiremav"
    }
  }
}
